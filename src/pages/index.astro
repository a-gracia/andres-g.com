---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import rischioPreview from "../assets/projects/rischio.io.png";
import Repositories from "../components/Repositories.astro";

const pageTitle = "Full Stack Developer & Scientific Programmer";
const projects = [
  {
    name: "Rischio.io",
    url: "https://rischio.io",
    image: rischioPreview,
    description:
      "Design and analyze geotechnical engineering structures such as retaining walls, deep foundations and shallow foundations.",
  },
];
---

<BaseLayout pageTitle={pageTitle}>
  <p>
    I build web apps with <a
      class="default-link"
      href="https://rubyonrails.org/"
      target="_blank">Ruby on Rails</a
    >, <a
      class="default-link"
      href="https://fastapi.tiangolo.com/"
      target="_blank">FastAPI</a
    >, <a class="default-link" href="https://react.dev/" target="_blank"
      >React</a
    > and <a class="default-link" href="https://astro.build/" target="_blank"
      >Astro</a
    >.
  </p>

  <p>
    I also develop scientific software using <a
      class="default-link"
      href="https://www.python.org/"
      target="_blank">Python</a
    > and
    <a
      class="default-link"
      href="https://www.mathworks.com/products/matlab.html"
      target="_blank">MATLAB</a
    >.
  </p>

  <p>
    Follow me on <a
      class="default-link"
      href="https://github.com/a-gracia"
      target="_blank">Github</a
    >!
  </p>

  <h2>Projects</h2>

  <div class="card-container">
    {projects.map((project) => <ProjectCard project={project} />)}
  </div>

  <h2>Code</h2>
  <div class="card-container">
    <Repositories />
  </div>
</BaseLayout>
